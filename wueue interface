#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

Node* rear = NULL;

void enqueue(int value) {
    Node* newNode = new Node;
    newNode->data = value;

    if (rear == NULL) {
        rear = newNode;
        rear->next = rear;
    } else {
        newNode->next = rear->next;
        rear->next = newNode;
        rear = newNode;
    }
    cout << "Inserted: " << value << endl;
}

void dequeue() {
    if (rear == NULL) {
        cout << "Queue is Empty\n";
        return;
    }

    Node* temp = rear->next;

    if (rear == temp) {
        cout << "Deleted: " << temp->data << endl;
        rear = NULL;
    } else {
        cout << "Deleted: " << temp->data << endl;
        rear->next = temp->next;
    }

    delete temp;
}

void peek() {
    if (rear == NULL) {
        cout << "Queue is Empty\n";
    } else {
        cout << "Front element: " << rear->next->data << endl;
    }
}


void display() {
    if (rear == NULL) {
        cout << "Queue is Empty\n";
        return;
    }

    Node* temp = rear->next;

    cout << "Queue elements: ";
    do {
        cout << temp->data << " ";
        temp = temp->next;
    } while (temp != rear->next);

    cout << endl;
}


int main() {
    int choice, value;

    while (true) {
        cout << "\n--- Queue Interface ---\n";
        cout << "1. Enqueue\n2. Dequeue\n3. Peek\n4. Display\n5. Exit\n";
        cout << "Enter your choice: ";
        cin >> choice;

        switch (choice) {
            case 1:
                cout << "Enter value: ";
                cin >> value;
                enqueue(value);
                break;

            case 2:
                dequeue();
                break;

            case 3:
                peek();
                break;

            case 4:
                display();
                break;

            case 5:
                cout << "Exiting...\n";
                return 0;

            default:
                cout << "Invalid choice\n";
        }
    }
}